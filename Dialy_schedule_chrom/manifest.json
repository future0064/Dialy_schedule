{
  "manifest_version": 3,
  "name": "Daily Schedule",
  "version": "1.6.0",
  "description": "Daily task manager with history, priorities, and multi-language support.",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Daily Schedule"
  },
  "permissions": [
    "storage"
  ]
}
